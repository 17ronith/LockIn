{
  "manifest_version": 3,
  "name": "LockIn",
  "version": "0.2.0",
  "description": "Transform any YouTube video into a focused deep-work session.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtu.be/*",
    "https://lockin-dev.vercel.app/*"
  ],
  "action": {
    "default_title": "LockIn",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://lockin-dev.vercel.app/*"],
      "js": ["lockin-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
